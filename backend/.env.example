# JourneyFlicker Backend — Environment Variables
# ─────────────────────────────────────────────────────────────
# For LOCAL dev: copy this file to .env in the backend/ folder
# For VERCEL:    add all these in Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Admin credentials ─────────────────────────────────────────
ADMIN_USERNAME=Fliker
ADMIN_PASSWORD=JourneyFliker0465

# ── Server port (local only, Vercel ignores this) ─────────────
PORT=5174

# ── CORS ─────────────────────────────────────────────────────
# Local:      http://localhost:5173,http://localhost:5174
# Production: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Upstash Redis (used as Vercel KV-compatible database) ─────
# Get these from: https://console.upstash.com
# Create a Redis DB → REST API tab → copy the values below
KV_REST_API_URL=https://xxxxxxxx.upstash.io
KV_REST_API_TOKEN=AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA
KV_URL=https://xxxxxxxx.upstash.io

# ── Cloudinary (image uploads) ────────────────────────────────
# Get these from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
