# JourneyFlicker Backend — Environment Variables
# ─────────────────────────────────────────────────────────────
# For LOCAL dev: copy this to .env in the backend/ folder
# For VERCEL: add all these in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Admin credentials ─────────────────────────────────────────
ADMIN_USERNAME=Fliker
ADMIN_PASSWORD=JourneyFliker0465

# ── Server port (local only) ──────────────────────────────────
PORT=5174

# ── CORS — set to your Vercel frontend URL in production ──────
# Local:      http://localhost:5173,http://localhost:5174
# Production: https://journeyflicker.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Vercel KV (auto-filled when you link KV store in dashboard)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Vercel Blob (auto-filled when you link Blob store in dashboard)
BLOB_READ_WRITE_TOKEN=
