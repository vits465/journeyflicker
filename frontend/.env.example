# JourneyFlicker Frontend — Environment Variables
# Copy this file to .env.local for local development
# Set these in your hosting platform's dashboard for production

# ── API URL ───────────────────────────────────────────────────────────────
# Local development (Vite proxy or direct backend URL)
VITE_API_URL=http://localhost:5174/api

# Production (replace with your deployed backend URL)
# Railway example:  https://journeyflicker-api.up.railway.app/api
# Render example:   https://journeyflicker-api.onrender.com/api
# Vercel example:   https://journeyflicker-api.vercel.app/api
